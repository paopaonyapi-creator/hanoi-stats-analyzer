# === Database ===
DATABASE_URL="postgresql://user:password@localhost:5432/hanoi_stats?schema=public"
# Direct connection URL (for Prisma migrations — bypasses connection pooler)
DIRECT_URL="postgresql://user:password@localhost:5432/hanoi_stats?schema=public"

# === App ===
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Hanoi Stats Analyzer"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DISCLAIMER="ระบบนี้เป็นเครื่องมือวิเคราะห์ข้อมูลย้อนหลังเชิงสถิติเท่านั้น ไม่ใช่การรับประกันผล"
APP_TIMEZONE=Asia/Bangkok

# === Security ===
# Secret key to protect the GET /api/cron/sync-daily endpoint
CRON_SECRET="your-cron-secret-here"
# Secret token for Telegram webhook verification
TELEGRAM_SECRET="hanoi_default_secret"

# === Trend Score Weights (optional — defaults used if omitted) ===
SCORE_WEIGHT_ALL_TIME=1
SCORE_WEIGHT_RECENT=1.5
SCORE_WEIGHT_GAP=1.2
SCORE_WEIGHT_TRANSITION=1
SCORE_WEIGHT_DIGIT_BALANCE=0.8
SCORE_WEIGHT_REPEAT=1
SCORE_WEIGHT_WEEKDAY=0.7

